VITE_AZURE_CLIENT_ID=your-azure-ad-client-id
VITE_AZURE_TENANT_ID=your-azure-ad-tenant-id
VITE_SP_SITE_URL=https://pmwgroupcom.sharepoint.com/sites/PMWHRDocs

# API authentication — must match server-side API_SECRET_KEY
VITE_API_SECRET_KEY=change-me-to-a-random-string

# Server-side API authentication
API_SECRET_KEY=change-me-to-the-same-random-string
CRON_SECRET=change-me-to-a-separate-random-string

# Server-side app-only Microsoft 365 credentials
SYSTEM_CLIENT_ID=your-system-app-client-id
SYSTEM_CLIENT_SECRET=your-system-app-client-secret

# SharePoint REST app-only certificate auth.
SHAREPOINT_CERT_PFX_BASE64=base64-encoded-pfx
SHAREPOINT_CERT_PASSWORD=your-pfx-export-password

# Server-side Microsoft Graph email senders
HR_FORM_EMAIL_FROM_ADDRESS=forms-no-reply@example.com
JOB_APPLICATION_EMAIL_FROM_ADDRESS=recruitment-no-reply@example.com
EMAIL_FROM_ADDRESS=shared-fallback@example.com

# Job application recipient
HR_RECRUITMENT_EMAIL=recruitment@example.com
